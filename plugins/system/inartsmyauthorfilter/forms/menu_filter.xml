<?xml version="1.0" encoding="UTF-8"?>
<form>
    <fields name="params">
        <fieldset name="inarts_author_filter" label="PLG_SYSTEM_INARTSMYAUTHORFILTER_FIELDSET_LABEL">
            <field
                name="inarts_author_filter_enabled"
                type="radio"
                label="PLG_SYSTEM_INARTSMYAUTHORFILTER_ONLY_OWN_LABEL"
                default="0"
                layout="joomla.form.field.radio.switcher"
                filter="integer"
            >
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>

            <field
                name="inarts_author_filter_include_drafts"
                type="radio"
                label="PLG_SYSTEM_INARTSMYAUTHORFILTER_INCLUDE_DRAFTS_LABEL"
                default="0"
                layout="joomla.form.field.radio.switcher"
                filter="integer"
                showon="inarts_author_filter_enabled:1"
            >
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>
        </fieldset>
    </fields>
</form>
